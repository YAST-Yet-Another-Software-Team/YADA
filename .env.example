NODE_ENV=development
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/yada
VITE_AUTH0_DOMAIN=
VITE_AUTH0_CLIENT_ID=
VITE_GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_API_KEY=
# Maps feature flag (optional; leave unset to auto-enable when a Maps key is configured)
VITE_MAPS_ENABLED=true
BETTER_AUTH_SECRET=
# Use your LAN IP when testing on phone (must match the URL in the browser)
BETTER_AUTH_URL=http://localhost:5173
# Comma-separated extras, e.g. http://172.20.10.3:5173
BETTER_AUTH_TRUSTED_ORIGINS=http://172.20.10.3:5173
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
SOCKET_CORS_ORIGIN=http://localhost:5173
